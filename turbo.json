{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "postinstall": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**", "gen/**", ".expo/**"],
      "env": ["VITE_DEMO_MODE", "VITE_API_URL", "VITE_ZERO_HOSTNAME", "VITE_WEB_HOSTNAME"]
    },
    "dev": {
      "dependsOn": ["^build"],
      "persistent": true,
      "cache": false
    },
    "check": {
      "dependsOn": ["^build"]
    },
    "check:all": {
      "dependsOn": ["^build"]
    },
    "lint": {},
    "test": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    }
  }
}

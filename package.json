{
  "name": "vine",
  "version": "0.0.1",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "type": "module",
  "engines": {
    "node": "24.3.0"
  },
  "packageManager": "bun@1.3.9",
  "scripts": {
    "postinstall": "turbo postinstall",
    "check": "tko check",
    "check:all": "tko check --all",
    "dev": "turbo dev",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "backend:clean": "docker compose down --volumes --remove-orphans --rmi local",
    "backend": "bun --cwd apps/web run migrate:build && docker compose up --remove-orphans"
  },
  "devDependencies": {
    "@fastify/cors": "10",
    "oxfmt": "^0.16.0",
    "oxlint": "^1.31.0",
    "turbo": "^2"
  },
  "overrides": {
    "@expo/fingerprint": "0.15.3",
    "sharp": "npm:@tamagui/proxy-worm@1.123.14",
    "expo-modules-core": "55.0.15",
    "expo-constants": "55.0.9",
    "expo-linking": "55.0.8",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-worklets": "0.7.2"
  },
  "trustedDependencies": [
    "@rocicorp/zero-sqlite3",
    "oxc-parser"
  ]
}
